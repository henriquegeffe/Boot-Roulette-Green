rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Permite ler o próprio perfil ou se for admin
      allow read: if isOwner(userId) || isAdmin();
      
      // Permite que o e-mail mestre crie seu primeiro perfil de admin
      // Ou que um admin existente crie outros usuários
      allow create: if (isSignedIn() && request.auth.token.email == 'henrique.geffe.89@gmail.com') || isAdmin();
      
      // Apenas admins ou o próprio dono (para campos limitados) podem atualizar
      allow update: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }
  }
}
